{
  "colorscheme": "atom-dark",
  "autosave": true,
  "basename": true,
  "tabstospaces": true,
  "tabsize": 4,
  "mkparents": true,
  "hlsearch": true,
  "savecursor": true,
  "saveundo": true,
  "scrollbar": true,
  "literate": true,
  "softwrap": true,
  "statusformatl": " $(filename)",
  "statusformatr": "$(line):$(col)  $(opt:encoding)  $(opt:fileformat)  $(opt:filetype) ",
  "*.json*": {
    "tabsize": 2
  }
}
