{{- $interactive := stdinIsATTY -}}

{{- $headless := false -}}
{{- if or (env "SSH_CONNECTION") (eq .chezmoi.username "root") (eq .chezmoi.osRelease.id "debian" "ubuntu") -}}
{{-   $headless = true -}}
{{- end -}}

{{- $email := "yidaduizuoye@outlook.com" -}}
{{- if $interactive -}}
{{-   $email = promptStringOnce . "email" "email" -}}
{{- end -}}

{{- $firefoxId := "" -}}
{{- if not $headless -}}
{{-     if eq .chezmoi.os "linux" -}}
{{-         $firefoxId = mozillaInstallHash "/usr/bin/firefox" -}}
{{-     end -}}
{{- end -}}

[data]
    headless = {{ $headless }}
    email = {{ $email | quote }}

    firefoxId = {{ $firefoxId | quote }}
    firefoxPath = "default-release"

[git]
    autoCommit = true

[diff]
    command = "difft"
